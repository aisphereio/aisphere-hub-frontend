# Next 开发期代理到 SkillHub 后端
SKILLHUB_BACKEND_URL=http://127.0.0.1:18001

# Casdoor 登录成功后回到前端的 callback path。
# 开发期 Next: /auth/callback
# Gin 托管 /ui 静态前端时，可以改为 /ui/ 并直接使用后端 callback localStorage 方案。
NEXT_PUBLIC_AUTH_CALLBACK_PATH=/auth/callback
NEXT_PUBLIC_AUTH_REDIRECT_AFTER_LOGIN=/
NEXT_PUBLIC_AISPHERE_AUTH_ENABLED=false
