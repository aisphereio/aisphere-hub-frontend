# ─── Hub Frontend Environment Configuration ───────────────────────────────
#
# Hub 前端通过 Envoy Gateway 进行 OIDC 认证。
# 推荐使用独立子域名：hub.weagent.cc
# 前端和 API 经同一个应用域名访问，从根本上避免跨域问题。
#
# API Origin:  https://hub.weagent.cc
# Frontend:    http://localhost:3000
# Casdoor:     https://casdoor.weagent.cc
# Callback:    https://hub.weagent.cc/oauth2/callback
# ──────────────────────────────────────────────────────────────────────────

# Hub API origin. Same-origin in production (empty), set for local dev.
NEXT_PUBLIC_HUB_URL=https://hub.weagent.cc:30723
NEXT_PUBLIC_IAM_URL=https://hub.weagent.cc:30723

# Auth mode: gateway_oidc = Envoy Gateway handles OIDC browser session.
NEXT_PUBLIC_AUTH_MODE=gateway_oidc
